<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Corrected invoice · {{invoice.reference}}</title>
  </head>
  <body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a; padding: 24px; max-width: 600px; margin: 0 auto;">
    <h2 style="margin-top: 0;">Your Schos invoice has been updated</h2>
    <p>We're sending you a corrected version of invoice <strong>{{invoice.reference}}</strong> for {{invoice.termLabel}}. The previous PDF is superseded.</p>

    <table style="border-collapse: collapse; width: 100%; margin: 18px 0; font-size: 14px;">
      <thead>
        <tr>
          <th style="text-align: left; padding: 8px 0; border-bottom: 1px solid #e5e5e5;">Field</th>
          <th style="text-align: right; padding: 8px 0; border-bottom: 1px solid #e5e5e5;">Was</th>
          <th style="text-align: right; padding: 8px 0; border-bottom: 1px solid #e5e5e5;">Now</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="padding: 6px 0;">Total amount</td>
          <td style="text-align: right; padding: 6px 0; color: #666;">{{diff.previousTotal}}</td>
          <td style="text-align: right; padding: 6px 0; font-weight: 600;">{{diff.newTotal}}</td>
        </tr>
        <tr>
          <td style="padding: 6px 0;">Student count</td>
          <td style="text-align: right; padding: 6px 0; color: #666;">{{diff.previousCount}}</td>
          <td style="text-align: right; padding: 6px 0; font-weight: 600;">{{diff.newCount}}</td>
        </tr>
      </tbody>
    </table>

    <p style="background: #fef3c7; border-left: 4px solid #f59e0b; padding: 12px 16px; border-radius: 4px;">
      <strong>Reason:</strong> {{diff.reason}}
    </p>

    <p>The updated PDF is attached. Please use it for your records and ignore the previous one.</p>

    <p style="color: #666; font-size: 12px; margin-top: 24px;">— The Schos team</p>
  </body>
</html>
