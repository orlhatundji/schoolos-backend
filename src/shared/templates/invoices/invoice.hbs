<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice · {{invoice.reference}}</title>
    <style>
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        color: #1a1a1a;
        background: #fafafa;
        margin: 0;
        padding: 24px;
        font-size: 13px;
        line-height: 1.5;
      }
      .container {
        max-width: 720px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        padding: 24px 28px 20px;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
      }
      .brand-block { font-size: 18px; font-weight: 600; color: #111; }
      .brand-sub { font-size: 11px; color: #666; margin-top: 4px; }
      .invoice-meta { text-align: right; }
      .invoice-meta .label { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 0.6px; }
      .invoice-meta .value { font-size: 13px; color: #1a1a1a; margin-top: 2px; }
      .hero {
        padding: 28px;
        text-align: center;
        background: linear-gradient(180deg, #fafafa 0%, #fff 100%);
      }
      .hero h1 {
        margin: 0;
        font-size: 36px;
        font-weight: 700;
        color: #111;
        letter-spacing: -0.5px;
      }
      .hero .badge {
        display: inline-block;
        margin-top: 8px;
        padding: 4px 10px;
        font-size: 11px;
        font-weight: 600;
        color: #b45309;
        background: #fef3c7;
        border-radius: 999px;
        letter-spacing: 0.4px;
      }
      .section { padding: 18px 28px; border-top: 1px solid #f0f0f0; }
      .section-title { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 0.6px; font-weight: 600; margin: 0 0 8px; }
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      .billed-to { font-size: 13px; }
      .billed-to .name { font-weight: 600; }
      .billed-to .line { color: #444; margin-top: 2px; }
      table.lines { width: 100%; border-collapse: collapse; font-size: 13px; }
      table.lines th, table.lines td { padding: 8px 0; text-align: left; }
      table.lines th { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 0.6px; border-bottom: 1px solid #e5e5e5; }
      table.lines td.amount, table.lines th.amount { text-align: right; }
      table.lines tr.total td { padding-top: 12px; border-top: 1px solid #e5e5e5; font-weight: 700; }
      .pay-block {
        padding: 20px 28px;
        background: #f7f9fc;
        font-size: 12px;
      }
      .pay-block .title { font-weight: 600; color: #111; margin-bottom: 6px; }
      .pay-block ul { margin: 0; padding-left: 18px; color: #444; }
      .footer {
        padding: 14px 28px;
        background: #fafafa;
        color: #888;
        font-size: 11px;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div>
          <div class="brand-block">Schos</div>
          <div class="brand-sub">School operating system</div>
        </div>
        <div class="invoice-meta">
          <div class="label">Invoice</div>
          <div class="value">{{invoice.reference}}</div>
          <div class="label" style="margin-top: 6px;">Issued</div>
          <div class="value">{{invoice.issuedAtDisplay}}</div>
        </div>
      </div>

      <div class="hero">
        <h1>{{invoice.totalDisplay}}</h1>
        <div class="badge">DUE · {{invoice.termLabel}}</div>
      </div>

      <div class="section">
        <p class="section-title">Billed to</p>
        <div class="billed-to">
          <div class="name">{{school.name}}</div>
          {{#if school.addressLine}}<div class="line">{{school.addressLine}}</div>{{/if}}
          {{#if school.email}}<div class="line">{{school.email}}</div>{{/if}}
        </div>
      </div>

      <div class="section">
        <p class="section-title">For</p>
        <div>Schos term service · {{invoice.termLabel}}</div>
      </div>

      <div class="section">
        <p class="section-title">Breakdown</p>
        <table class="lines">
          <thead>
            <tr>
              <th>Description</th>
              <th class="amount">Amount</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>{{invoice.studentCount}} active students × {{invoice.unitFeeDisplay}}/student</td>
              <td class="amount">{{invoice.totalDisplay}}</td>
            </tr>
            <tr class="total">
              <td>Total due</td>
              <td class="amount">{{invoice.totalDisplay}}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="pay-block">
        <div class="title">How to pay</div>
        <ul>
          <li>Pay online from your admin portal: open <strong>Invoices</strong> → click <strong>Pay now</strong>.</li>
          <li>Or settle externally (bank transfer) and notify Schos to mark this invoice paid.</li>
        </ul>
      </div>

      <div class="footer">
        Powered by Schos · Questions? Email <a href="mailto:support@schos.ng">support@schos.ng</a>.
      </div>
    </div>
  </body>
</html>
