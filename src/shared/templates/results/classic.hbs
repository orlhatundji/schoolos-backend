<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  :root {
    --theme-color: {{themeColor}};
    --theme-text-color: {{themeTextColor}};
    --theme-row-bg: {{themeRowBg}};
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; color: #333; display: flex; flex-direction: column; }
  #report-root { width: 100%; min-height: {{paperContentMinHeight}}; display: flex; flex-direction: column; box-sizing: border-box; }
  .report-body { flex: 1; display: flex; flex-direction: column; min-height: 0; }
  .table-bottom-spacer { flex: 1 1 auto; min-height: 18px; }
  .report-bottom { flex-shrink: 0; display: flex; flex-direction: column; gap: 12px; }

  .header { background: #2c3e50; padding: 15px 20px; position: relative; }
  .header-top { background: var(--theme-color); padding: 10px 20px; text-align: center; }
  .school-name { color: var(--theme-text-color); font-size: 20px; font-weight: bold; letter-spacing: 1px; }
  .school-subtitle { color: var(--theme-text-color); opacity: 0.85; font-size: 11px; margin-top: 4px; }
  .school-address { color: var(--theme-text-color); opacity: 0.85; font-size: 10px; margin-top: 2px; }
  .school-phone { color: var(--theme-text-color); opacity: 0.85; font-size: 10px; margin-top: 2px; }
  .report-title-box {
    background: #ecf0f1; border: 1px solid #bdc3c7;
    display: inline-block; padding: 5px 25px; margin-top: 8px;
    font-size: 14px; font-weight: bold; color: #2c3e50;
  }
  .header-accent { height: 3px; background: var(--theme-color); }

  .header-top { position: relative; }
  .logo-img {
    position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
    width: 58px; height: 58px; object-fit: contain;
    background: #ecf0f1; border: 2px solid var(--theme-color); padding: 2px;
  }

  .student-info {
    background: #f8f9fa; border: 1px solid #e9ecef;
    padding: 10px 15px; margin: 12px 0;
    display: grid; grid-template-columns: 1fr 1fr auto;
    gap: 12px; align-items: start;
  }
  .student-details-col { display: flex; flex-direction: column; gap: 3px; }
  .student-photo {
    width: 72px; height: 72px; aspect-ratio: 1 / 1;
    background: #fff; overflow: hidden;
    flex-shrink: 0;
  }
  .student-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .info-item { font-size: 10px; line-height: 1.35; }
  .info-label { font-weight: bold; color: var(--theme-color); }
  .info-value { color: #2c3e50; font-weight: bold; }

  .results-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
  .results-table thead th {
    background: var(--theme-color); color: var(--theme-text-color);
    padding: 8px 4px; font-size: 10px; text-align: center;
    border-top: 3px solid var(--theme-color);
  }
  .results-table tbody td {
    padding: 6px 4px; text-align: center; font-size: 10px;
    border-bottom: 1px solid #e9ecef;
  }
  .results-table tbody tr:nth-child(even) { background: var(--theme-row-bg); }
  .results-table tbody tr:nth-child(odd) { background: #ffffff; }
  .subject-name { text-align: left !important; font-weight: bold; padding-left: 8px !important; }
  .total-cell { font-weight: bold; color: #2c3e50; font-size: 11px; }
  .results-table { border: 2px solid var(--theme-color); }

  .summary-box {
    background: #ecf0f1; border: 1px solid #bdc3c7;
    padding: 8px 15px;
    border-top: 3px solid var(--theme-color);
  }
  .summary-title { font-size: 12px; font-weight: bold; color: #2c3e50; margin-bottom: 4px; }
  .summary-text { font-size: 10px; color: #495057; }

  .remarks-box {
    background: #f8f9fa; border: 1px solid #e9ecef;
    padding: 8px 15px;
  }
  .remarks-title { font-weight: bold; font-size: 11px; color: #2c3e50; margin-bottom: 4px; }
  .remarks-text { font-size: 10px; color: #495057; line-height: 1.4; }

  .signatures {
    background: #f8f9fa; border: 1px solid #e9ecef;
    padding: 10px 15px;
  }
  .signature-grid { display: flex; justify-content: space-between; gap: 20px; }
  .sig-block { flex: 1; text-align: center; }
  .sig-label { font-weight: bold; font-size: 10px; color: #2c3e50; margin-bottom: 6px; }
  .sig-image { height: 40px; margin: 0 auto; }
  .sig-line { border-bottom: 1px solid #bdc3c7; height: 40px; }
  .sig-name { font-size: 9px; color: #495057; margin-top: 4px; }

  .footer {
    background: #2c3e50; color: #ecf0f1;
    padding: 6px 20px; margin-top: 0;
    display: flex; justify-content: space-between;
    font-size: 9px;
  }

  .grading-key {
    margin-top: 0; display: inline-block;
  }
  .grading-key table { border-collapse: collapse; font-size: 9px; }
  .grading-key th { background: var(--theme-color); color: var(--theme-text-color); padding: 3px 8px; }
  .grading-key td { border: 1px solid #ddd; padding: 3px 8px; text-align: center; }
</style>
</head>
<body>

<div id="report-root">
<div class="header-top">
  <img class="logo-img" src="{{logoSrc}}" alt="Logo">
  <div class="school-name">{{school.name}}</div>
  {{#if school.motto}}
  <div class="school-subtitle">{{school.motto}}</div>
  {{/if}}
  {{#if school.address}}<div class="school-address">{{school.address}}</div>{{/if}}
  {{#if school.phone}}<div class="school-phone">Tel: {{school.phone}}</div>{{/if}}
  <div class="report-title-box">ACADEMIC REPORT CARD</div>
</div>
<div class="header-accent"></div>

<div style="padding: 0 15px;" class="report-body">

  <div class="student-info">
    <div class="student-details-col">
    <div class="info-item">
      <span class="info-label">NAME: </span>
      <span class="info-value">{{student.fullName}}</span>
    </div>
    <div class="info-item">
      <span class="info-label">STUDENT NO: </span>
      <span class="info-value">{{student.studentNo}}</span>
    </div>
    <div class="info-item">
      <span class="info-label">SESSION: </span>
      <span class="info-value">{{academicSession.academicYear}}</span>
    </div>
    </div>
    <div class="student-details-col">
    <div class="info-item">
      <span class="info-label">CLASS: </span>
      <span class="info-value">{{student.classArm.level.name}} {{student.classArm.name}}</span>
    </div>
    <div class="info-item">
      <span class="info-label">TERM: </span>
      <span class="info-value">{{term.name}}</span>
    </div>
    <div class="info-item">
      <span class="info-label">PERIOD: </span>
      <span class="info-value">{{termStartDate}} - {{termEndDate}}</span>
    </div>
    {{#if attendance}}
    <div class="info-item">
      <span class="info-label">ATTENDANCE: </span>
      <span class="info-value">{{#if attendance.daysAttended}}{{attendance.daysAttended}}{{else}}-{{/if}}/{{#if attendance.daysOpen}}{{attendance.daysOpen}}{{else}}-{{/if}}</span>
    </div>
    {{/if}}
    </div>
    {{#if avatarSrc}}
    <div class="student-photo" style="border-radius: {{photoBorderRadius}};">
      <img src="{{avatarSrc}}" alt="Student Photo">
    </div>
    {{/if}}
  </div>

  <table class="results-table">
    <thead>
      <tr>
        <th style="width:30px">S/N</th>
        <th style="text-align:left; padding-left:8px;">Subject</th>
        {{#each previousTerms}}
        <th>{{this.name}}<br><small>Total</small></th>
        {{/each}}
        {{#each assessmentStructures}}
        <th>{{this.name}}<br><small>({{this.maxScore}})</small></th>
        {{/each}}
        <th>Total</th>
        {{#if hasPreviousTerms}}<th>Cum.<br><small>Avg</small></th>{{/if}}
        <th>Grade</th>
        <th>Position</th>
        <th style="width:70px">Remarks</th>
      </tr>
    </thead>
    <tbody>
      {{#each subjects}}
      <tr>
        <td>{{this.serialNumber}}</td>
        <td class="subject-name">{{this.name}}</td>
        {{#each this.previousTermTotals}}
        <td style="color:#7f8c8d; font-weight: bold;">{{#if this}}{{this}}{{else}}-{{/if}}</td>
        {{/each}}
        {{#each this.assessments}}
        <td style="color: {{#if this.score}}{{../scoreColor}}{{else}}#999{{/if}}; font-weight: bold;">
          {{#if this.score}}{{this.score}}{{else}}-{{/if}}
        </td>
        {{/each}}
        <td class="total-cell">{{this.totalScore}}</td>
        {{#if ../hasPreviousTerms}}<td class="total-cell" style="color:#2c3e50;">{{fixed this.cumulativeAverage 1}}</td>{{/if}}
        <td style="color: {{this.gradeColor}}; font-weight: bold; font-size: 11px;">{{or this.grade "-"}}</td>
        <td style="font-weight: bold;">{{or this.position "N/A"}} / {{this.totalStudentsInSubject}}</td>
        <td style="color: {{this.remarkColor}}; font-weight: bold; font-size: 9px;">{{this.remark}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="table-bottom-spacer"></div>

  <div class="report-bottom">
  <div class="summary-box">
    <div class="summary-title">Academic Summary</div>
    <div class="summary-text">
      Total Subjects: {{overallStats.totalSubjects}} &bull;
      Total Score: {{overallStats.totalScore}} &bull;
      Average: {{fixed overallStats.averageScore 1}}% &bull;
      Grade: {{or overallStats.grade "N/A"}} &bull;
      Position: {{or overallStats.position "N/A"}} of {{overallStats.totalStudents}}
    </div>
  </div>

  {{#if gradingModel}}
  <div class="grading-key">
    <table>
      <tr>
        <th>Grade</th>
        {{#each gradingModel}}
        <th>{{@key}}</th>
        {{/each}}
      </tr>
      <tr>
        <td><strong>Range</strong></td>
        {{#each gradingModel}}
        <td>{{this.[0]}} - {{this.[1]}}</td>
        {{/each}}
      </tr>
    </table>
  </div>
  {{/if}}

  <div class="remarks-box">
    <div class="remarks-title">Class Teacher's Remark</div>
    <div class="remarks-text">
      {{#if teacherComment}}{{teacherComment}}{{else}}____________________________________________________________________________________________________________{{/if}}
    </div>
  </div>

  <div class="remarks-box">
    <div class="remarks-title">Principal's Remark</div>
    <div class="remarks-text">
      {{#if principalComment}}{{principalComment}}{{else}}____________________________________________________________________________________________________________{{/if}}
    </div>
  </div>

  <div class="signatures">
    <div class="signature-grid">
      <div class="sig-block">
        <div class="sig-label">Teacher Signature:</div>
        {{#if teacherSignatureUrl}}
          <img src="{{teacherSignatureUrl}}" class="sig-image" style="object-fit:contain;" alt="Teacher Signature">
        {{else}}
          <div class="sig-line"></div>
        {{/if}}
        {{#if teacherName}}<div class="sig-name">{{teacherName}}</div>{{/if}}
      </div>
      <div class="sig-block">
        <div class="sig-label">Principal Signature:</div>
        {{#if principalSignatureUrl}}
          <img src="{{principalSignatureUrl}}" class="sig-image" style="object-fit:contain;" alt="Principal Signature">
        {{else}}
          <div class="sig-line"></div>
        {{/if}}
        {{#if principalName}}<div class="sig-name">{{principalName}}</div>{{/if}}
      </div>
    </div>
  </div>

  <div class="footer">
    <span>Generated on: {{generatedDate}}</span>
    <span>Powered by Schos</span>
  </div>
  </div>

</div>

</div>

</body>
</html>
