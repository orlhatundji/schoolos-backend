<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  :root {
    --theme-color: {{themeColor}};
    --theme-text-color: {{themeTextColor}};
    --theme-row-bg: {{themeRowBg}};
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 11px; color: #1a1a1a; background: #fff;
    display: flex; flex-direction: column;
  }
  #report-root { width: 100%; min-height: {{paperContentMinHeight}}; display: flex; flex-direction: column; box-sizing: border-box; }
  .report-body { flex: 1; display: flex; flex-direction: column; min-height: 0; }
  .table-bottom-spacer { flex: 1 1 auto; min-height: 18px; }
  .report-bottom { flex-shrink: 0; display: flex; flex-direction: column; gap: 12px; }

  .page {
    position: relative; display: flex; flex-direction: column; flex: 1; min-height: 0;
    padding: 12px 16px 10px;
  }

  .watermark {
    position: absolute; top: 38%; left: 50%;
    transform: translate(-50%, -50%);
    width: 220px; height: 220px; opacity: 0.06;
    pointer-events: none; z-index: 0;
  }
  .watermark img { width: 100%; height: 100%; object-fit: contain; }

  .page-content { position: relative; z-index: 1; flex: 1; display: flex; flex-direction: column; min-height: 0; }

  .header {
    display: flex; align-items: center; gap: 12px;
    padding-bottom: 8px; border-bottom: 2px solid var(--theme-color);
  }
  .logo-box {
    width: 68px; height: 68px; flex-shrink: 0; overflow: hidden;
  }
  .logo-box img { width: 100%; height: 100%; object-fit: contain; }
  .header-text { flex: 1; text-align: center; }
  .school-name {
    font-size: 16px; font-weight: 800; color: #1a1a1a;
    text-transform: uppercase; letter-spacing: 0.5px; line-height: 1.2;
  }
  .school-meta { font-size: 9px; color: #444; margin-top: 3px; line-height: 1.4; }

  .report-title-bar {
    text-align: center; font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.5px;
    padding: 6px 0; margin-bottom: 8px;
    border-bottom: 1px solid #ccc;
  }

  .student-info {
    display: grid; grid-template-columns: 1fr 1fr auto;
    gap: 10px; align-items: start;
    margin-bottom: 10px; font-size: 10px;
  }
  .info-col { display: flex; flex-direction: column; gap: 3px; }
  .info-row { display: flex; gap: 4px; line-height: 1.35; }
  .info-label { font-weight: 700; color: #1a1a1a; white-space: nowrap; }
  .info-value { color: #1a1a1a; }
  .info-value.bold { font-weight: 700; text-transform: uppercase; }
  .student-photo {
    width: 72px; height: 72px; aspect-ratio: 1 / 1;
    background: #f5f5f5; overflow: hidden; flex-shrink: 0;
    align-self: start;
  }
  .student-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .results-table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  .results-table th, .results-table td {
    border: 1px solid var(--theme-color); padding: 4px 3px;
    text-align: center; font-size: 9px;
  }
  .results-table thead th {
    background: var(--theme-color); color: var(--theme-text-color);
    font-weight: 700; text-transform: uppercase;
    font-size: 8px; letter-spacing: 0.2px;
  }
  .results-table tbody tr:nth-child(even) { background: var(--theme-row-bg); }
  .subject-name {
    text-align: left !important; font-weight: 600;
    padding-left: 6px !important; text-transform: uppercase;
    font-size: 8px;
  }
  .total-cell { font-weight: 700; }
  .remark-cell { font-size: 8px; font-weight: 600; text-transform: uppercase; }

  .grading-section {
    font-size: 9px; line-height: 1.5;
    border-top: 1px solid #ccc; padding-top: 8px;
  }
  .grading-section .line { margin-bottom: 2px; }
  .grading-section strong { font-weight: 700; }
  .average-score {
    margin-top: 4px; font-size: 11px; font-weight: 800;
    text-transform: uppercase;
  }

  .remarks-table {
    width: 100%; border-collapse: collapse; margin-top: 0;
    font-size: 10px;
  }
  .remarks-table th, .remarks-table td {
    border: 1px solid var(--theme-color); padding: 6px 8px;
    text-align: left; vertical-align: top;
  }
  .remarks-table th {
    background: var(--theme-color); color: var(--theme-text-color);
    font-weight: 700; width: 180px;
    text-transform: uppercase; font-size: 9px;
  }
  .remarks-table td { min-height: 28px; font-size: 9px; color: #333; }

  .signature-block {
    margin-top: 0; display: flex; align-items: flex-end; gap: 12px;
  }
  .sig-image-wrap { height: 36px; }
  .sig-image-wrap img { height: 36px; object-fit: contain; }
  .sig-line { border-bottom: 1px solid #1a1a1a; width: 160px; height: 36px; }
  .sig-details { font-size: 9px; line-height: 1.4; }
  .sig-name { font-weight: 700; text-transform: uppercase; }
  .sig-title { color: #444; }

  .motto-footer {
    margin-top: 0; padding-top: 0;
    text-align: center; font-size: 13px; font-weight: 700;
    color: #bbb; text-transform: uppercase; letter-spacing: 3px;
    font-style: italic;
  }

  .footer-meta {
    margin-top: 0; display: flex; justify-content: space-between;
    font-size: 8px; color: #888;
  }
</style>
</head>
<body>

<div class="page" id="report-root">
  <div class="watermark">
    <img src="{{logoSrc}}" alt="">
  </div>

  <div class="page-content report-body">

    <div class="header">
      <div class="logo-box">
        <img src="{{logoSrc}}" alt="Logo">
      </div>
      <div class="header-text">
        <div class="school-name">{{school.name}}</div>
        <div class="school-meta">
          {{#if school.address}}{{school.address}}{{/if}}
          {{#if school.phone}}{{#if school.address}} &bull; {{/if}}Tel: {{school.phone}}{{/if}}
        </div>
      </div>
      <div class="logo-box" style="visibility:hidden;">
        <img src="{{logoSrc}}" alt="">
      </div>
    </div>

    <div class="report-title-bar">
      {{student.classArm.level.name}} {{student.classArm.name}} &mdash;
      {{term.name}} {{academicSession.academicYear}} STUDENT REPORT
    </div>

    <div class="student-info">
      <div class="info-col">
        <div class="info-row">
          <span class="info-label">Name:</span>
          <span class="info-value bold">{{student.fullName}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Student No:</span>
          <span class="info-value">{{student.studentNo}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Session:</span>
          <span class="info-value">{{academicSession.academicYear}}</span>
        </div>
        {{#if attendance}}
        <div class="info-row">
          <span class="info-label">Attendance:</span>
          <span class="info-value">{{#if attendance.daysAttended}}{{attendance.daysAttended}}{{else}}-{{/if}}/{{#if attendance.daysOpen}}{{attendance.daysOpen}}{{else}}-{{/if}}</span>
        </div>
        {{/if}}
      </div>
      <div class="info-col">
        <div class="info-row">
          <span class="info-label">Class:</span>
          <span class="info-value">{{student.classArm.level.name}} {{student.classArm.name}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Term:</span>
          <span class="info-value">{{term.name}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Period:</span>
          <span class="info-value">{{termStartDate}} &mdash; {{termEndDate}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">No. in Class:</span>
          <span class="info-value">{{overallStats.totalStudents}} Students</span>
        </div>
      </div>
      {{#if avatarSrc}}
      <div class="student-photo" style="border-radius: {{photoBorderRadius}};">
        <img src="{{avatarSrc}}" alt="Student Photo">
      </div>
      {{/if}}
    </div>

    <table class="results-table">
      <thead>
        <tr>
          <th style="width:24px">S/N</th>
          <th style="text-align:left; padding-left:6px;">Subject</th>
          {{#each previousTerms}}
          <th>{{this.name}}<br><small>Total</small></th>
          {{/each}}
          {{#each assessmentStructures}}
          <th>{{this.name}}<br><small>({{this.maxScore}})</small></th>
          {{/each}}
          <th>Total<br><small>({{totalMaxScore}})</small></th>
          {{#if hasPreviousTerms}}<th>Cum.<br><small>Avg</small></th>{{/if}}
          <th>Grade</th>
          <th>Subject<br><small>Pos.</small></th>
          <th>Grade<br><small>Remark</small></th>
        </tr>
      </thead>
      <tbody>
        {{#each subjects}}
        <tr>
          <td>{{this.serialNumber}}</td>
          <td class="subject-name">{{this.name}}</td>
          {{#each this.previousTermTotals}}
          <td>{{#if this}}{{this}}{{else}}-{{/if}}</td>
          {{/each}}
          {{#each this.assessments}}
          <td style="font-weight:600;">{{#if this.score}}{{this.score}}{{else}}-{{/if}}</td>
          {{/each}}
          <td class="total-cell">{{this.totalScore}}</td>
          {{#if ../hasPreviousTerms}}<td class="total-cell">{{fixed this.cumulativeAverage 1}}</td>{{/if}}
          <td style="font-weight:700; color:{{this.gradeColor}};">{{or this.grade "-"}}</td>
          <td style="font-weight:600;">{{or this.position "N/A"}}/{{this.totalStudentsInSubject}}</td>
          <td class="remark-cell" style="color:{{this.remarkColor}};">{{this.remark}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="table-bottom-spacer"></div>

    <div class="report-bottom">
    <div class="grading-section">
      {{#if gradingModel}}
      <div class="line"><strong>Key to Grades:</strong>
        {{#each gradingModel}}{{ @key }}: {{this.[0]}}%{{#unless @last}}, {{/unless}}{{/each}}
      </div>
      {{/if}}
      {{#if gradesSummary}}
      <div class="line"><strong>Grades Summary:</strong> {{gradesSummary}}</div>
      {{/if}}
      <div class="average-score">Average Score: {{fixed overallStats.averageScore 0}}</div>
      <div class="line" style="margin-top:4px;">
        <strong>Class Position:</strong> {{or overallStats.position "N/A"}} of {{overallStats.totalStudents}}
        &bull; <strong>Overall Grade:</strong> {{or overallStats.grade "N/A"}}
      </div>
    </div>

    <table class="remarks-table">
      <tr>
        <th>Form Teacher's Remarks:</th>
        <td>{{#if teacherComment}}{{teacherComment}}{{else}}&nbsp;{{/if}}</td>
      </tr>
      <tr>
        <th>Principal's Remarks:</th>
        <td>{{#if principalComment}}{{principalComment}}{{else}}&nbsp;{{/if}}</td>
      </tr>
    </table>

    <div class="signature-block">
      <div>
        {{#if principalSignatureUrl}}
          <div class="sig-image-wrap">
            <img src="{{principalSignatureUrl}}" alt="Principal Signature">
          </div>
        {{else}}
          <div class="sig-line"></div>
        {{/if}}
        <div class="sig-details">
          {{#if principalName}}<div class="sig-name">{{principalName}}</div>{{/if}}
          <div class="sig-title">Director/Principal</div>
        </div>
      </div>
    </div>

    {{#if school.motto}}
    <div class="motto-footer">{{school.motto}}</div>
    {{/if}}

    <div class="footer-meta">
      <span>Generated on: {{generatedDate}}</span>
      <span>Powered by Schos</span>
    </div>
    </div>

  </div>
</div>

</body>
</html>
